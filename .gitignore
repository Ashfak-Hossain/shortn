# === Go ===
# Test binaries from `go test -c`
*.test
# Coverage output from `go test -coverprofile`
coverage.out
coverage.html
# Local-only Go workspace files
go.work
go.work.sum
# Local build output (the real build happens in Docker; locally we use `go run`)
/bin/

# === Environment / secrets ===
# Config comes from env vars — never commit real values. Commit a template instead.
.env
.env.*
!.env.example

# === macOS ===
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
*.icloud

# === VS Code (ignore the folder, keep shared project config) ===
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# === Git merge / backup artifacts ===
*.orig
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*.REMOTE.*

# === Project-private (the guided curriculum is not for the public repo) ===
# Ignore docs/ contents,
docs/*
PLAN.md

# === Machine-specific Claude config (shared .claude/settings.json stays tracked) ===
.claude/settings.local.json
